{
  "redirects": [
    {
      "source": "/about",
      "destination": "/nosotros",
      "statusCode": 301
    },
    {
      "source": "/projects",
      "destination": "/proyectos",
      "statusCode": 301
    },
    {
      "source": "/contacto",
      "destination": "/contact",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}